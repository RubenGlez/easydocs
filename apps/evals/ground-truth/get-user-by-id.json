{
  "tags": ["users"],
  "summary": "Get a user by id",
  "parameters": [
    { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
  ],
  "responses": {
    "200": {
      "description": "The requested user",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "email": { "type": "string" },
              "role": { "type": "string" },
              "createdAt": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
