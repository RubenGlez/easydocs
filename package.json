{
  "name": "easydocs",
  "version": "0.5.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' --filter './apps/*' dev",
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter './apps/*' build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "seed": "tsx scripts/seed-traffic.ts",
    "eval": "pnpm --filter easydocs-evals eval",
    "release": "node scripts/release.mjs",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^10.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.4"
  }
}
