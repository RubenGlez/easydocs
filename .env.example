# AI provider — at least one key required
# Provider is auto-detected from whichever key is present.
# Explicit config via easydocs({ ai: { provider: 'anthropic' } }) overrides this.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Storage — optional, defaults to ~/.easydocs/db.sqlite
# EASYDOCS_DB_URL=file:/absolute/path/to/easydocs.sqlite

# Dashboard — optional, used by apps/dashboard to find the database
# EASYDOCS_DB_URL=file:/absolute/path/to/easydocs.sqlite

# Dashboard path — optional, used by autoStart to locate apps/dashboard
# EASYDOCS_DASHBOARD_PATH=/absolute/path/to/apps/dashboard
