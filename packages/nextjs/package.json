{
  "name": "@easydocs/nextjs",
  "version": "0.5.2",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "EasyDocs handler wrapper for Next.js App Router and Pages Router",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "next": "^16.2.6",
    "tsup": "^8.3.0",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RubenGlez/easydocs",
    "directory": ""
  }
}
