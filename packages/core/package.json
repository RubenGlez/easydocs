{
  "name": "@easydocs/core",
  "version": "0.1.0",
  "description": "AI processing, storage, and spec building for EasyDocs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/storage/schema.js",
      "require": "./dist/storage/schema.cjs",
      "types": "./dist/storage/schema.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/openai": "^1.1.4",
    "@libsql/client": "^0.14.0",
    "ai": "^4.1.8",
    "drizzle-orm": "^0.39.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5"
  }
}
