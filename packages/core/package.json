{
  "name": "@easydocs/core",
  "version": "0.5.3",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "AI processing, storage, and spec building for EasyDocs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/storage/schema.js",
      "require": "./dist/storage/schema.cjs",
      "types": "./dist/storage/schema.d.ts"
    },
    "./spec/schema": {
      "import": "./dist/spec/schema.js",
      "require": "./dist/spec/schema.cjs",
      "types": "./dist/spec/schema.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/openai": "^3.0.64",
    "@libsql/client": "^0.17.3",
    "ai": "^6.0.185",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vite": "8.0.13",
    "vitest": "^4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RubenGlez/easydocs",
    "directory": ""
  }
}
