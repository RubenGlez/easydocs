{
  "name": "@easydocs/cli",
  "version": "0.8.0",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "EasyDocs CLI — capture via proxy, export OpenAPI specs, and diff specs in CI. Runs locally.",
  "type": "module",
  "bin": {
    "easydocs": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsup && vitest run"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RubenGlez/easydocs",
    "directory": ""
  }
}
