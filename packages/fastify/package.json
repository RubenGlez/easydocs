{
  "name": "@easydocs/fastify",
  "version": "0.8.0",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "OpenAPI docs for Fastify, generated from real traffic. Local-first, self-hostable, open source.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*",
    "fastify-plugin": "^5.0.0"
  },
  "peerDependencies": {
    "fastify": ">=4.0.0"
  },
  "devDependencies": {
    "@fastify/type-provider-typebox": "^4.0.0",
    "fastify": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vite": "8.1.0",
    "vitest": "^4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RubenGlez/easydocs",
    "directory": ""
  }
}
