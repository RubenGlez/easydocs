{
  "name": "@easydocs/fastify",
  "version": "0.1.4",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "EasyDocs plugin for Fastify",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*",
    "fastify-plugin": "^5.0.0"
  },
  "peerDependencies": {
    "fastify": ">=4.0.0"
  },
  "devDependencies": {
    "@fastify/type-provider-typebox": "^4.0.0",
    "fastify": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5"
  }
}
