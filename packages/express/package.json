{
  "name": "@easydocs/express",
  "version": "0.5.3",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "EasyDocs middleware for Express",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "express": "^5.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vite": "8.0.13",
    "vitest": "^4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RubenGlez/easydocs",
    "directory": ""
  }
}
