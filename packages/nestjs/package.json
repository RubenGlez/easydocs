{
  "name": "@easydocs/nestjs",
  "version": "0.1.1",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "EasyDocs module for NestJS",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.3.0",
    "typescript": "^5"
  }
}
