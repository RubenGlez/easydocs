{
  "name": "@easydocs/elysia",
  "version": "0.1.2",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "EasyDocs plugin for Elysia (Bun)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*"
  },
  "peerDependencies": {
    "elysia": ">=1.0.0"
  },
  "devDependencies": {
    "elysia": "^1.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5"
  }
}
