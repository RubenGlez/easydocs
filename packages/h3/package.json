{
  "name": "@easydocs/h3",
  "version": "0.5.1",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "EasyDocs plugin for h3, Nitro, and Nuxt",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@easydocs/core": "workspace:*"
  },
  "peerDependencies": {
    "h3": ">=1.0.0"
  },
  "devDependencies": {
    "h3": "^1.13.0",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vite": "8.0.13",
    "vitest": "^4.1.6"
  }
}
